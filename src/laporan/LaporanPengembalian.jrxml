	<queryString language="SQL">
		<![CDATA[SELECT
    pg.kode_pengembalian,
    ps.kode_sewa,
    pg.tanggal_kembali,
    pg.hari_terlambat,
    pg.total_denda
FROM pengembalian pg
JOIN penyewaan ps
    ON pg.id_sewa = ps.id_sewa
WHERE pg.is_deleted = 0
ORDER BY pg.tanggal_kembali DESC]]>
	</queryString>
