<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="LaporanPenyewaan" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b8d84bfd-be94-4e87-b592-a17c88562978">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL_RentalMobil"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<queryString>
		<![CDATA[SELECT
    ps.kode_sewa,
    py.nama,
    k.merk,
    k.model,
    ps.tanggal_sewa,
    ps.tanggal_jatuh_tempo,
    ps.lama_sewa,
    ps.total_bayar
FROM penyewaan ps
JOIN penyewa py
    ON ps.id_penyewa = py.id_penyewa
JOIN kendaraan k
    ON ps.id_kendaraan = k.id_kendaraan
WHERE ps.is_deleted = 0
ORDER BY ps.tanggal_sewa DESC]]>
	</queryString>
