	<queryString language="SQL">
		<![CDATA[SELECT
    kode_kendaraan,
    merk,
    model,
    jenis_kendaraan,
    plat_nomor,
    tahun,
    warna,
    harga_sewa,
    status
FROM kendaraan
WHERE is_deleted = 0
ORDER BY merk]]>
